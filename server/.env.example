# Gmail Configuration
# Replace with your Gmail address and app-specific password
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-16-character-app-password

# Email sender display name/address
EMAIL_FROM=noreply@afcsme.com.ph

# Email recipients
# Application & Contact forms go here:
FORMS_EMAIL=admin@afcsme.com.ph

# Inquiry forms:
INQUIRIES_EMAIL=admin@afcsme.com.ph

# Foreclosed properties form:
FORECLOSED_PROPERTIES_EMAIL=jadmin@afcsme.com.ph

# CC for all admin-side form notifications:
FORMS_CC_EMAIL=admin@afcsme.com.ph

# Server Port
PORT=4000

# CORS
# Comma-separated list of allowed frontend origins. Leave empty only when
# your frontend is served from the same origin as the API.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Bootstrap admin user for fresh deployments
# Use a strong password (12+ characters).
ADMIN_BOOTSTRAP_USERNAME=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-before-deploying

# Security and rate limits
SESSION_TTL_MS=1800000
MAX_BODY_BYTES=2097152
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
FORM_RATE_LIMIT_MAX=8
FORM_RATE_LIMIT_WINDOW_MS=600000
ADMIN_MUTATION_RATE_LIMIT_MAX=30
ADMIN_MUTATION_RATE_LIMIT_WINDOW_MS=60000
